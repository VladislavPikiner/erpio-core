  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "eslint": "9.20.0",
    "typescript": "5.7.3"
  }
